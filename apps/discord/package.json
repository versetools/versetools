		"discord.js": "catalog:discord",
		"discordthing": "^0.2.3"
	},
	"devDependencies": {
		"@versetools/convex-client": "workspace:*",
		"@versetools/core": "workspace:*",
		"@versetools/observability": "workspace:*"
	},
	"packageManager": "pnpm@10.24.0"
}