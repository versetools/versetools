{
	"name": "@versetools/discord",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "tsgo --noEmit",
		"dev": "tsx --env-file-if-exists=.env.local --watch --watch-preserve-output src/main.ts",
		"format": "prettier --write .",
		"lint": "eslint . && prettier --check .",
		"lint-fix": "eslint . --fix && prettier --check --write .",
