{
	"name": "@versetools/ui-consent",
	"version": "0.7.0",
	"description": "Consent svelte component",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*"
	],
	"scripts": {
		"dev": "vite dev",
		"sync": "svelte-kit sync",
		"build": "svelte-kit sync && svelte-package",
		"package": "pnpm build",
		"prepublishOnly": "pnpm package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"watch": "svelte-kit sync && svelte-package --watch"
	},
	"author": "l3dotdev",
	"license": "UNLICENSED",
	"peerDependencies": {
		"@l3dev-private/consent": "^0.3.0",
		"@l3dev-private/consent-svelte": ">=0.6.2 <1.0.0",
		"@sveltejs/kit": "^2.20.5",
		"@versetools/ui": ">=0.22.0 <1.0.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"dependencies": {
		"@lucide/svelte": "^0.554.0",
		"@melt-ui/svelte": "^0.86.0",
		"tailwind-merge": "^3.2.0",
		"tailwind-variants": "^1.0.0"
	},
	"devDependencies": {
		"@floating-ui/dom": "^1.6.13",
		"@sveltejs/package": "^2.5.0",
		"@sveltejs/vite-plugin-svelte": "^6.1.3",
		"@tailwindcss/vite": "^4.1.3",
		"svelte": "^5.38.3",
		"svelte-check": "^4.3.1",
		"svelte-exmarkdown": "^5.0.2",
		"tailwindcss": "^4.1.4",
		"vite": "^6.2.6"
	}
}