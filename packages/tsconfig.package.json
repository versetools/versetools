{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"noErrorTruncation": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"inlineSources": true,
		"strict": true,
		"strictNullChecks": true,
		"stripInternal": true,
		"noImplicitAny": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"declaration": true,
		"noEmit": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"lib": ["esnext"]
	}
}
